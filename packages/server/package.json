{
  "name": "@ai-productivity-tracker/server",
  "version": "0.0.0",
  "private": true,
  "description": "HTTP daemon: serves /ai-productivity/* JSON API + transcript-watcher + static dashboard. Bundled into cli; not published directly.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo .cache *.tsbuildinfo"
  },
  "dependencies": {
    "@ai-productivity-tracker/core": "workspace:*",
    "@ai-productivity-tracker/hook-core": "workspace:*"
  }
}
