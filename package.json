{
  "name": "ai-productivity-tracker-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Independent AI productivity tracking toolkit — daemon + MCP + Hook + Web dashboard, distributable via npm.",
  "license": "MIT",
  "author": "zhongleijian",
  "homepage": "https://github.com/zhongleijian/ai-productivity-tracker",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhongleijian/ai-productivity-tracker.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r --if-present run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
